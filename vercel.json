{
  "rewrites": [
    { "source": "/gen", "destination": "/generator.html" },
    { "source": "/admin", "destination": "/admin/login.html" },
    { "source": "/dashboard", "destination": "/admin/dashboard.html" },
    { "source": "/api/links/:code?", "destination": "/api/links.js" },
